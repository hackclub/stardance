<%
  active_week = lockin_active_week
  display_week = lockin_display_week
  status_text = lockin_status_text
%>

<% content_for :title, "Dashboard: #{@sidequest.title}" %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>

<div class="sidequest-show sidequest-show--lockin">
  <div class="sidequest-show__content">

    <div class="lockin-dashboard">

      <div class="lockin-header">
        <h1 class="lockin-header__title--massive">LockIn week #<%= display_week %></h1>

        <% if @selected_project %>
          <% total_hours = @week_seconds / 3600.0 %>
          <% progress_percent = [(total_hours / 10.0) * 100, 100].min %>

          <div class="lockin-progress">
            <div class="lockin-progress__track">
              <% 10.times do |i| %>
                <% filled = total_hours >= (i + 1) %>
                <% partial = !filled && total_hours > i %>
                <div class="lockin-progress__segment <%= 'lockin-progress__segment--filled' if filled %><%= ' lockin-progress__segment--partial' if partial %><%= ' lockin-progress__segment--complete' if progress_percent >= 100 %>">
                  <% if partial %>
                    <div class="lockin-progress__segment-inner" style="width: <%= ((total_hours - i) * 100).round %>%;"></div>
                  <% end %>
                  <span class="lockin-progress__segment-label"><%= i + 1 %></span>
                </div>
              <% end %>
            </div>
            <div class="lockin-progress__labels">
              <span>0 hrs</span>
              <strong><%= format('%.1f', total_hours) %> hrs now</strong>
              <span>10 hrs</span>
            </div>
          </div>

          <% if @daily_pace_needed && @hours_done < 10.0 %>
            <p class="lockin-pace-indicator">
              <i class="fa-solid fa-gauge-high"></i>
              You need <strong><%= @daily_pace_needed %> hrs/day</strong> to hit 10hrs this week.
            </p>
          <% elsif @hours_done >= 10.0 %>
            <p class="lockin-pace-indicator lockin-pace-indicator--done">
              <i class="fa-solid fa-check-circle"></i>
              Week goal hit! You're a survivor! 🎉
            </p>
          <% end %>
        <% else %>
          <p class="lockin-header__subtitle">Select this week's project below to track your progress!</p>
        <% end %>
      </div>

      <div class="lockin-grid">
        <div class="lockin-card">
          <h3 class="lockin-card__title"><i class="fa-solid fa-crosshairs"></i> Current Mission Details</h3>

          <form action="<%= dash_sidequest_path(@sidequest) %>" method="get" class="lockin-project-selector" data-controller="autosubmit">
            <label for="project_id" class="lockin-project-selector__label">Select Project for Week <%= display_week %>:</label>
            <div class="lockin-project-selector__input-group">
              <select name="project_id" id="project_id" class="lockin-project-selector__select" onchange="this.form.submit()">
                <% unless @selected_project %>
                  <option value="">-- Choose a project --</option>
                <% end %>
                <% @projects.each do |project| %>
                  <option value="<%= project.id %>" <%= "selected" if @selected_project&.id == project.id %>><%= project.title %></option>
                <% end %>
              </select>
            </div>
            <% if @projects.empty? %>
              <p class="lockin-project-selector__error">You need to create a project to track progress.</p>
            <% end %>
          </form>

          <% if @selected_project %>
            <%# Project preview card %>
            <div class="lockin-project-preview">
              <% if @selected_project.banner.attached? %>
                <div class="lockin-project-preview__banner">
                  <%= image_tag @selected_project.banner.variant(:card), class: "lockin-project-preview__img", alt: @selected_project.title %>
                </div>
              <% end %>
              <div class="lockin-project-preview__info">
                <h4 class="lockin-project-preview__name">
                  <%= link_to @selected_project.title, project_path(@selected_project) %>
                </h4>
                <% if @selected_project.repo_url.present? %>
                  <p class="lockin-project-preview__commit lockin-project-preview__commit--empty">
                    Connected to <%= begin; URI.parse(@selected_project.repo_url).host; rescue URI::InvalidURIError, URI::BadURIError; "Git"; end %>
                  </p>
                <% end %>
              </div>
            </div>

            <div class="lockin-countdown">
              <h4 class="lockin-countdown__title">Time Remaining in Week <%= display_week %></h4>
              <div id="lockin-countdown" data-deadline="<%= @week_end.iso8601 %>" class="lockin-countdown__timer">
                <span class="timer-text">--:--:--:--</span>
              </div>
            </div>
            <script>
              document.addEventListener("turbo:load", function() {
                const countdownEl = document.getElementById("lockin-countdown");
                if (!countdownEl) return;
                const deadlineStr = countdownEl.getAttribute("data-deadline");
                if (!deadlineStr) return;
                const deadline = new Date(deadlineStr).getTime();
                const textSpan = countdownEl.querySelector(".timer-text");
                const timer = setInterval(function() {
                  const now = new Date().getTime();
                  const distance = deadline - now;
                  if (distance < 0) {
                    clearInterval(timer);
                    textSpan.innerHTML = "0d 0h 0m 0s";
                    return;
                  }
                  const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                  const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                  const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                  const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                  textSpan.innerHTML = days + "d " + hours + "h " + minutes + "m " + seconds + "s";
                }, 1000);
              });
            </script>
          <% end %>
        </div>

        <% if @selected_project %>
        <div class="lockin-card">
          <h3 class="lockin-card__title"><i class="fa-solid fa-clipboard-list"></i> Week <%= display_week %> Updates</h3>
          <p class="lockin-card__date-range">From <%= @week_start.strftime("%b %d, %Y") %> to <%= @week_end.strftime("%b %d, %Y") %></p>

          <% if @accomplishments.any? %>
            <div class="lockin-accomplishments">
              <% @accomplishments.each do |devlog| %>
                <div class="lockin-accomplishment">
                  <div class="lockin-accomplishment__header">
                    <strong class="lockin-accomplishment__type">
                      <i class="fa-solid fa-code"></i> Devlog
                    </strong>
                    <span class="lockin-accomplishment__time"><%= time_ago_in_words(devlog.created_at) %> ago</span>
                  </div>
                  <p class="lockin-accomplishment__body"><%= truncate(devlog.postable.body, length: 150) %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="lockin-empty-state">
              <i class="fa-regular fa-folder-open fa-2x lockin-empty-state__icon"></i>
              <p>No devlogs or commits found for this week.</p>
              <p class="lockin-empty-state__subtitle">Make sure to post your progress to earn your hours!</p>
            </div>
          <% end %>
        </div>
        <% end %>

        <% if @past_weeks_data.present? && @past_weeks_data.any? %>
        <div class="lockin-card">
          <h3 class="lockin-card__title"><i class="fa-solid fa-clock-rotate-left"></i> Past Weeks Summary</h3>
          <div class="lockin-past-weeks">
            <% @past_weeks_data.each do |pw| %>
              <div class="lockin-past-week">
                <h4 class="lockin-past-week__header">
                  Week <%= pw[:week_num] %>
                  <span class="lockin-past-week__dates">(<%= pw[:start_date].strftime("%b %d") %> - <%= pw[:end_date].strftime("%b %d") %>)</span>
                </h4>
                <div class="lockin-past-week__stats">
                  <span class="lockin-past-week__total-hours <%= pw[:total_hours] >= 10 ? 'lockin-past-week__total-hours--complete' : 'lockin-past-week__total-hours--pending' %>"><%= pw[:total_hours].round(1) %> / 10 Hrs Total</span>
                </div>

                <% if pw[:active_projects].any? %>
                  <ul class="lockin-past-week__projects">
                    <% pw[:active_projects].each do |ap| %>
                      <li class="lockin-past-week__project">
                        <%= link_to ap[:project].title, project_path(ap[:project]), class: "lockin-past-week__project-name" %>
                        <div class="lockin-past-week__project-stats">
                          <span class="lockin-past-week__project-stat"><i class="fa-solid fa-clock"></i> <%= ap[:hours].round(1) %> hrs</span>
                          <span class="lockin-past-week__project-stat"><i class="fa-solid fa-pen"></i> <%= ap[:posts_count] %> posts</span>
                        </div>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="lockin-past-week__empty">No active projects recorded for this week.</p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
        <% end %>

      </div>
    </div>

    <div class="sidequest-show__actions" style="margin-top: 2rem;">
      <%= render ButtonComponent.new(
            text: "\u2190 Back to Lock In",
            href: sidequest_path(@sidequest),
            color: :red,
            variant: :borderless
          ) %>
    </div>
  </div>
</div>
