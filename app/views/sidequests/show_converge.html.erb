<% content_for :title, @sidequest.title %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>
<%= render HeadingComponent.new(title: @sidequest.title, tone: :blue, size: :full) %>

<div class="sidequest-show sidequest-show--converge">
  <div class="sidequest-show__content">
    <div class="converge-workspace">
      <div class="converge-sidebar">
        <div class="converge-sidebar__workspace">
          <span class="converge-sidebar__workspace-icon">C</span>
          <span class="converge-sidebar__workspace-name">Converge HQ</span>
        </div>
        <div class="converge-sidebar__channels">
          <div class="converge-sidebar__section-label">Channels</div>
          <a href="#about" class="converge-sidebar__channel converge-sidebar__channel--active"># about</a>
          <a href="#requirements" class="converge-sidebar__channel"># requirements</a>
          <a href="#ideas" class="converge-sidebar__channel"># ideas</a>
          <a href="#submissions" class="converge-sidebar__channel"># submissions</a>
        </div>
      </div>

      <div class="converge-main">
        <div class="converge-channel-header">
          <span class="converge-channel-header__name"># about</span>
          <span class="converge-channel-header__topic">Build bots that bring communities together</span>
        </div>

        <div class="converge-messages">
          <div class="converge-message" id="about">
            <%= image_tag "https://cdn.mahadk.com/s/v3/ab7c183beb51aa7d_image.png", class: "converge-message__avatar converge-message__avatar--bot", alt: "ConvergeBot" %>
            <div class="converge-message__body">
              <div class="converge-message__header">
                <span class="converge-message__author">ConvergeBot</span>
                <span class="converge-message__badge">APP</span>
                <span class="converge-message__time">Today</span>
              </div>
              <div class="converge-message__text">
                <p><strong>Welcome to Converge!</strong></p>
                <p><%= @sidequest.description %></p>
                <p>
                    Bots are the backbone of online communities. They moderate, entertain, inform and automate. (And more importantly, they're fun as hell to make <i>and</i> to use!
                    This sidequest challenges you to build a bot for <strong>Slack</strong> or <strong>Discord</strong> that does something genuinely useful or delightfully creative.
                </p>
              </div>
            </div>
          </div>

          <div class="converge-message" id="requirements">
            <%= image_tag "https://cdn.mahadk.com/s/v3/ab7c183beb51aa7d_image.png", class: "converge-message__avatar converge-message__avatar--bot", alt: "ConvergeBot" %>
            <div class="converge-message__body">
              <div class="converge-message__header">
                <span class="converge-message__author">ConvergeBot</span>
                <span class="converge-message__badge">APP</span>
                <span class="converge-message__time">Today</span>
              </div>
              <div class="converge-message__text">
                <p><strong>Requirements</strong></p>
                <ul>
                  <li>Your bot must work on <strong>Slack</strong> and/or <strong>Discord</strong></li>
                  <li>It must respond to at least one slash command or event</li>
                  <li>Include a README with setup instructions and a demo (screenshot or video)</li>
                  <li>Your bot must be open source on GitHub</li>
                  <li>Ship your project on Stardance</li>
                  <li>Submit it to this sidequest from your project page</li>
                  <li>Make it actually interesting! Think to yourself, "is this something I'll actually <i>use?</i>"</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="converge-message" id="ideas">
            <%= image_tag "https://cdn.mahadk.com/s/v3/ab7c183beb51aa7d_image.png", class: "converge-message__avatar converge-message__avatar--bot", alt: "ConvergeBot" %>
            <div class="converge-message__body">
              <div class="converge-message__header">
                <span class="converge-message__author">ConvergeBot</span>
                <span class="converge-message__badge">APP</span>
                <span class="converge-message__time">Today</span>
              </div>
              <div class="converge-message__text">
                <p><strong>Bot ideas to get you started?</strong></p>
                <div class="converge-message__ideas-grid">
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">🎵</span>
                    <div>
                      <strong>Musicbot</strong>
                      <p>Queue and play music in voice channels</p>
                    </div>
                  </div>
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">📊</span>
                    <div>
                      <strong>Poll bot</strong>
                      <p>Like Polly or Denopoll on the Slack!</p>
                    </div>
                  </div>
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">🛡️</span>
                    <div>
                      <strong>Automod</strong>
                      <p>Auto-moderate content, manage roles, require CAPTCHAs on joining...</p>
                    </div>
                  </div>
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">🎮</span>
                    <div>
                      <strong>Minigames</strong>
                      <p>Trivia, RPG, or mini-games in chat! (hint: look at the Slack Video Embed API!)</p>
                    </div>
                  </div>
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">📅</span>
                    <div>
                      <strong>Scheduler bot</strong>
                      <p>Manage events, reminders, and todos</p>
                    </div>
                  </div>
                  <div class="converge-message__idea">
                    <span class="converge-message__idea-icon">🔗</span>
                    <div>
                      <strong>Integrate with external services</strong>
                      <p>Bridge services like GitHub, Fizzy, or any other API</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="converge-message" id="submissions">
            <%= image_tag "https://cdn.mahadk.com/s/v3/ab7c183beb51aa7d_image.png", class: "converge-message__avatar converge-message__avatar--bot", alt: "ConvergeBot" %>
            <div class="converge-message__body">
              <div class="converge-message__header">
                <span class="converge-message__author">ConvergeBot</span>
                <span class="converge-message__badge">APP</span>
                <span class="converge-message__time">Today</span>
              </div>
              <div class="converge-message__text">
                <p><strong><%= @approved_entries.size %> <%= "submission".pluralize(@approved_entries.size) %></strong> so far. Ship your bot and join them!</p>
              </div>
            </div>
          </div>
        </div>

        <div class="converge-composer">
          <div class="converge-composer__input">
            <span class="converge-composer__placeholder">Message #converge</span>
          </div>
        </div>
      </div>
    </div>

    <% if @approved_entries.any? %>
      <div class="sidequest-show__gallery">
        <h3 class="sidequest-show__gallery-title"><%= @approved_entries.size %> <%= "submission".pluralize(@approved_entries.size) %></h3>
        <div class="sidequest-show__gallery-grid">
          <% @approved_entries.each do |entry| %>
            <% project = entry.project %>
            <% next unless project.present? %>
            <div class="sidequest-show__gallery-item">
              <%= render partial: "projects/card", locals: { project: project } %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="sidequest-show__actions">
      <%= render ButtonComponent.new(
            text: "← Back to Sidequests",
            href: sidequests_path,
            color: :brown,
            variant: :borderless
          ) %>
    </div>
  </div>
</div>
