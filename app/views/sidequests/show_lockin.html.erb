<%
  active_week = lockin_active_week
  status_text = lockin_status_text

  deadlines = lockin_weeks.map { |w| w[:end] }

  next_deadline = if active_week == 0
                    lockin_weeks.first[:start]
                  else
                    deadlines.find { |d| Time.current < d }
                  end

  countdown_label = active_week == 0 ? "STARTS IN:" : "NEXT DEADLINE:"
%>
<% content_for :title, @sidequest.title %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>

<div class="sidequest-show sidequest-show--lockin">
  <div class="sidequest-show__content">

    <div class="lockin-dashboard">
      <div class="lockin-header">
        <h1 class="lockin-header__title"><i class="fa-solid fa-lock"></i> <%= @sidequest.title %></h1>
        <p class="lockin-header__desc"><%= @sidequest.description %></p>
        <p class="lockin-header__desc" style="margin-top: 1rem; font-weight: 700;">
          Join <a href="https://hackclub.enterprise.slack.com/archives/C0APA6DDC6N" style="color: #d4a373; text-decoration: underline;">#lockin-sidequest</a> on Slack and connect with other survivors!
        </p>

          <div style="margin-top: 1.5rem; display: flex; justify-content: center;">
            <%= render ButtonComponent.new(
                  text: "LockIn Dash",
                  href: dash_sidequest_path("lockin"),
                  color: :red,
                  variant: :borderless,
                ) %>
          </div>
      </div>

      <div class="lockin-weeks">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1rem;">
          <h3 class="lockin-weeks__title" style="margin-bottom: 0;">4-Week Mission (10 hrs / wk)</h3>
          <% if next_deadline %>
            <div id="lockin-countdown" data-deadline="<%= next_deadline.iso8601 %>" style="font-family: monospace; font-size: 1.1rem; font-weight: bold; color: #8c5a35; background: #fff8eb; padding: 0.25rem 0.75rem; border-radius: 6px; border: 1px solid #d4a373;">
              <span style="font-size: 0.8rem; color: #d4a373; margin-right: 0.5rem;"><%= countdown_label %></span>
              <span class="timer-text">--:--:--:--</span>
            </div>
          <% else %>
            <div style="font-family: monospace; font-size: 1.1rem; font-weight: bold; color: #8c5a35; background: #fff8eb; padding: 0.25rem 0.75rem; border-radius: 6px; border: 1px solid #d4a373;">
              MISSION OVER
            </div>
          <% end %>
        </div>

        <% if next_deadline %>
          <script>
            document.addEventListener("turbo:load", function() {
              const countdownEl = document.getElementById("lockin-countdown");
              if (!countdownEl) return;
              const deadlineStr = countdownEl.getAttribute("data-deadline");
              if (!deadlineStr) return;
              const deadline = new Date(deadlineStr).getTime();
              const textSpan = countdownEl.querySelector(".timer-text");
              const timer = setInterval(function() {
                const now = new Date().getTime();
                const distance = deadline - now;
                if (distance < 0) {
                  clearInterval(timer);
                  textSpan.innerHTML = "0d 0h 0m 0s";
                  return;
                }
                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                textSpan.innerHTML = days + "d " + hours + "h " + minutes + "m " + seconds + "s";
              }, 1000);
            });
          </script>
        <% end %>

        <div class="lockin-weeks__grid">
          <div class="lockin-weeks__box <%= 'active' if active_week == 1 %> <%= 'completed' if active_week > 1 %>">
            <span class="wk">
              <% if active_week > 1 %><i class="fa-solid fa-check"></i><% else %>Week 1<% end %>
            </span>
            <span class="hrs"><%= active_week == 1 ? 'Current' : '10 Hrs' %></span>
          </div>
          <div class="lockin-weeks__box <%= 'active' if active_week == 2 %> <%= 'completed' if active_week > 2 %>">
            <span class="wk">
              <% if active_week > 2 %><i class="fa-solid fa-check"></i><% else %>Week 2<% end %>
            </span>
            <span class="hrs"><%= active_week == 2 ? 'Current' : '10 Hrs' %></span>
          </div>
          <div class="lockin-weeks__box <%= 'active' if active_week == 3 %> <%= 'completed' if active_week > 3 %>">
            <span class="wk">
              <% if active_week > 3 %><i class="fa-solid fa-check"></i><% else %>Week 3<% end %>
            </span>
            <span class="hrs"><%= active_week == 3 ? 'Current' : '10 Hrs' %></span>
          </div>
          <div class="lockin-weeks__box <%= 'active' if active_week == 4 %> <%= 'completed' if active_week > 4 %>">
            <span class="wk">
              <% if active_week > 4 %><i class="fa-solid fa-check"></i><% else %>Week 4<% end %>
            </span>
            <span class="hrs"><%= active_week == 4 ? 'Current' : '10 Hrs' %></span>
          </div>
        </div>
      </div>

      <div class="lockin-grid">
        <div class="lockin-card">
          <h3 class="lockin-card__title"><i class="fa-solid fa-list-check"></i> Requirements</h3>
          <ul>
            <li>Work on a ship that has <strong>more than 10 hours</strong>.</li>
            <li>Count 10 hours within the weekly timeframe; older hours will cause rejection.</li>
            <li>Cannot ship more than one project or combine the hours.</li>
            <li>Purchase the <strong>Lockin Ticket</strong> in the shop to join.</li>
            <li>Mark each project as submitted for <strong>Lock in</strong> in its settings.</li>
          </ul>
        </div>

        <div class="lockin-card">
          <h3 class="lockin-card__title"><i class="fa-solid fa-calendar-days"></i> Mission Timeline</h3>
          <ul>
            <li><strong>Current Status:</strong> <%= status_text %></li>
            <li><strong>Starts:</strong> March 29th</li>
            <li><strong>Ends:</strong> April 30th</li>
            <li><strong>Week Cycle:</strong> Thursday 12 AM EST to Wednesday 11:59 PM EST (Except Week 1)</li>
            <li><strong>Week 1 Dates:</strong> March 29th to April 9th (Grace for Week 1)</li>
          </ul>
        </div>
      </div>

      <% if @prizes.present? && @prizes.any? %>
        <div class="lockin-card" style="margin-bottom: 2rem;">
          <h3 class="lockin-card__title"><i class="fa-solid fa-gift"></i> Unlockable Shop Prizes</h3>
          <div class="sidequest-show__prizes-list">
            <% @prizes.each do |prize| %>
              <%= link_to "/shop/order?shop_item_id=#{prize.id}", class: "sidequest-show__prize-row" do %>
                <% if prize.image.attached? %>
                  <div class="sidequest-show__prize-image">
                    <%= image_tag prize.image.variant(:carousel_sm), alt: prize.name, loading: "lazy" %>
                  </div>
                <% end %>
                <span class="sidequest-show__prize-name" style="color:#8c5a35;"><%= prize.name %></span>
                <span class="sidequest-show__prize-cost"><%= number_to_currency(prize.ticket_cost, precision: 0).gsub('$', '') %> 🍪</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="lockin-faq">
        <h3 class="lockin-faq__title">Mission Briefing (FAQ)</h3>
        <div class="lockin-faq__grid">
          <div class="faq-item">
            <h4>What is this?</h4>
            <p>LockIn is a 4-week program where you need to ship every week. Only hours shipped at the end of each week count. If you missed a week, you'll be out. If you make it to the end, you get 120 🍪 and unlock amazing prizes in the Stardance shop.</p>
          </div>

          <div class="faq-item">
            <h4>When Is LockIn?</h4>
            <p>Lockin starts March 29th and ends on April 30th. Every week starts from Thursday 12 AM EST to Wednesday 11:59 PM EST, except for Week 1, which starts from March 29th to April 9th. If you don't ship a project in Week 1, you cannot join.</p>
          </div>

          <div class="faq-item">
            <h4>Every week dates:</h4>
            <ul style="list-style: none; padding: 0;">
              <li><strong>Week One:</strong> March 29th to April 8th 11:59 PM EST</li>
              <li><strong>Week Two:</strong> April 9th to April 15th 11:59 PM EST</li>
              <li><strong>Week Three:</strong> April 16th to April 22nd 11:59 PM EST</li>
              <li><strong>Week Four:</strong> April 23rd to April 29th 11:59 PM EST</li>
            </ul>
          </div>

          <div class="faq-item">
            <h4>How can I sign up?</h4>
            <p>Purchase the item in the shop and, in the last stage of shipping, mark it as submitted for LockIn.</p>
          </div>

          <div class="faq-item">
            <h4>What if I did the 10 hours but shipped after the deadline?</h4>
            <p>If you completed the 10 hours within the weekly timeframe, you will have 24 hours to ship your project.</p>
          </div>

          <div class="faq-item">
            <h4>What if my ships got rejected from Shipwrights?</h4>
            <p>Just fix them and reship. It won’t be a problem as long as you completed the 10 hours without any fraud during the week.</p>
          </div>

          <div class="faq-item">
            <h4>Can I work on one project and ship multiple times?</h4>
            <p>Yes, but every ship needs to be 10 hours. It's recommended to work on 4 projects in order to try new things!</p>
          </div>

          <div class="faq-item">
            <h4>Can I join more than once at the same time?</h4>
            <p>Yes, but you’ll be required to do 20 hrs a week and you’ll get 240 cookies.</p>
          </div>

          <div class="faq-item">
            <h4>What counts as a valid project?</h4>
            <p>Must be 10 hours or more & follow Stardance guidelines.</p>
          </div>

          <div class="faq-item">
            <h4>Can I try again after failing?</h4>
            <p>No unfortunately, you cannot. Failure to ship 10 hours means you're out.</p>
          </div>

          <div class="faq-item">
            <h4>I discovered this late, can I join now?</h4>
            <p>You can’t, since this is a 4-week program. Stardance ends on April 30th, and LockIn ends at the same time.</p>
          </div>

          <div class="faq-item">
            <h4>Can I double dip with other sidequests?</h4>
            <p>You can only choose one sidequest per ship, but you can work a little more on another ship in the same project and select a different sidequest. The limitation applies to each ship, not the entire project.</p>
          </div>

          <div class="faq-item">
            <h4>OHH, What are the prizes I will unlock in the shop?</h4>
            <div class="lockin-prize-grid">
              <%= link_to "/shop/order?shop_item_id=216", class: "lockin-prize-item" do %>
                <i class="fa-solid fa-laptop"></i>
                <span>Laptop Grant</span>
              <% end %>
              <%= link_to "/shop/order?shop_item_id=217", class: "lockin-prize-item" do %>
                <i class="fa-solid fa-mobile-screen-button"></i>
                <span>Samsung A26 Phone</span>
              <% end %>
              <%= link_to "/shop/order?shop_item_id=218", class: "lockin-prize-item" do %>
                <i class="fa-solid fa-mobile-screen"></i>
                <span>iPhone 17e</span>
              <% end %>
              <%= link_to "/shop/order?shop_item_id=219", class: "lockin-prize-item" do %>
                <i class="fa-solid fa-tablet-screen-button"></i>
                <span>Lenovo Idea Tab 11 Tablet</span>
              <% end %>
            </div>
          </div>
          <div class="faq-item">
            <h4>What if I missed an hour?</h4>
            <p>You can make up the hours you lost over the past weeks, but for every hour you missed, you’ll need to make up an hour and 15 minutes. Also, the absolute minimum time for any project is 6 hours; anything less means you're out immediately.</p>
          </div>
        </div>
      </div>

    </div>

    <% if @approved_entries.any? %>
      <div class="sidequest-show__gallery">
        <h3 class="sidequest-show__gallery-title"><%= @approved_entries.size %> <%= "submission".pluralize(@approved_entries.size) %> (Survivors)</h3>
        <div class="sidequest-show__gallery-grid">
          <% @approved_entries.each do |entry| %>
            <% project = entry.project %>
            <% next unless project.present? %>
            <div class="sidequest-show__gallery-item">
              <%= render partial: "projects/card", locals: { project: project } %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="sidequest-show__actions" style="margin-top: 2rem;">
      <%= render ButtonComponent.new(
            text: "\u2190 Retreat to Sidequests",
            href: sidequests_path,
            color: :red,
            variant: :borderless
          ) %>
    </div>
  </div>
</div>
