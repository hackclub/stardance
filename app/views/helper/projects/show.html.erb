<% content_for :title, "Project ##{@project.id}" %>
<h1>Project #<%= @project.id %></h1>

<% if @project.deleted? %>
  <div class="alert alert-warning" style="margin-bottom: 1.5rem; padding: 1rem; background: #fee2e2; border-radius: 8px; border: 1px solid #dc2626; color: hsl(7, 40%, 25%);">
    <strong>⚠️ This project was deleted at <%= @project.deleted_at.strftime("%Y-%m-%d %H:%M") %></strong>
  </div>
<% end %>

<div class="flex" style="gap: 1rem; flex-wrap: wrap;">
  <div class="card">
    <h2>Details</h2>
    <div class="info-rows">
      <div><b>Author(s):</b> <%= sanitize @project.users.map { |u| link_to(u.display_name, helper_user_path(u)) }.to_sentence, tags: %w[a], attributes: %w[href] %></div>
      <div><b>Title:</b> <%= @project.title %></div>
      <div><b>Description:</b> <%= @project.description.presence || "None" %></div>
      <div><b>Has Banner:</b> <%= @project.banner.present? ? "Yes" : "No" %></div>
      <div><b>Ship Status:</b> <%= @project.ship_status.titleize %></div>
      <div><b>Devlog Count:</b> <%= @project.devlogs.count %></div>
      <div><b>Time Spent: </b> <%= distance_of_time_in_words(@project.duration_seconds) %></div>
      <% if @project.ai_declaration.present? %>
        <div><b>This user declared AI:</b> <%= @project.ai_declaration %></div>
      <% end %>
      <div><b>Type:</b> <%= @project.project_type.presence || "Not set" %></div>
      <div><b>Created:</b> <%= @project.created_at.strftime("%Y-%m-%d") %></div>
      <div><b>Deleted:</b> <%= @project.deleted? ? "Yes" : "No" %></div>
    </div>
  </div>

  <div class="card">
    <h2>Ship Events</h2>
    <% if @ship_events.any? %>
      <ul style="margin: 0; padding-left: 1.25rem;">
        <% @ship_events.each do |ship_event| %>
          <% legitimate_votes = ship_event.votes.payout_countable.order(created_at: :desc) %>
          <li>
            <%= ship_event.created_at.strftime("%Y-%m-%d %H:%M") %>
            — <%= ship_event.payout.present? ? "Paid" : "Not paid" %>
            — <%= ship_event.certification_status.titleize %>
            <% if ship_event.payout.blank? %>
              <% remaining = Post::ShipEvent::VOTES_REQUIRED_FOR_PAYOUT - legitimate_votes.size %>
              — votes: <%= legitimate_votes.size %>/<%= Post::ShipEvent::VOTES_REQUIRED_FOR_PAYOUT %> (<%= [remaining, 0].max %> left)
            <% end %>
            — <%= ship_event.body.presence || "No message for this event" %>
            <% if legitimate_votes.any? %>
              —
              <button type="button" class="btn-primary slim" onclick="document.getElementById(<%= "ship-event-feedback-modal-#{ship_event.id}".to_json %>).showModal()">View Feedback</button>
            <% end %>
          </li>

          <% if legitimate_votes.any? %>
            <%= render layout: "shared/modal", locals: { id: "ship-event-feedback-modal-#{ship_event.id}", title: "Feedback with ratings" } do %>
              <p style="margin-bottom: 0.75rem;"><strong><%= legitimate_votes.size %></strong> vote<%= legitimate_votes.size == 1 ? "" : "s" %> received</p>

              <% legitimate_votes.each_with_index do |vote, index| %>
                <div class="post__vote-entry">
                  <p>
                    <strong>Feedback:</strong>
                    &nbsp; <%= vote.time_taken_to_vote ? "#{vote.time_taken_to_vote}s" : "—" %>
                    <% opened = [ vote.demo_url_clicked? ? "Demo" : nil, vote.repo_url_clicked? ? "Repo" : nil ].compact %>
                    <%= "· Opened #{opened.join(', ')}" if opened.any? %>
                  </p>
                  <p><%= Vote::SCORE_COLUMNS_BY_CATEGORY.map { |cat, col| "#{cat.to_s.humanize} #{vote[col]}/9" }.join(" · ") %></p>
                  <blockquote class="post__vote-reason"><%= vote.reason %></blockquote>
                </div>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </ul>
    <% else %>
      <p>No ship events for this project</p>
    <% end %>
  </div>
</div>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
  <%= link_to "← Back", helper_projects_path, class: "btn-secondary no-margin" %>
  <% if @project.deleted? %>
    <%= button_to "Restore Project", restore_helper_project_path(@project),
      method: :post,
      class: "btn-primary",
      form: { onsubmit: "return confirm('Are you sure you want to restore this project?')" } %>
  <% else %>
    <%= button_to "View Project", project_path(@project),
      method: :get,
      class: "btn-primary",
      form: { target: "_blank", rel: "noopener" } %>
  <% end %>
</div>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem;">
  <% if @project.repo_url.present? && (URI.parse(@project.repo_url).scheme.in?(%w[http https]) rescue false) %>
    <%= link_to "View Repo", URI.parse(@project.repo_url).to_s, class: "btn-primary", target: "_blank", rel: "noopener" %>
  <% end %>

  <% if @project.demo_url.present? && (URI.parse(@project.demo_url).scheme.in?(%w[http https]) rescue false) %>
    <%= link_to "View Demo", URI.parse(@project.demo_url).to_s, class: "btn-primary", target: "_blank", rel: "noopener" %>
  <% end %>

  <% if @project.readme_url.present? && (URI.parse(@project.readme_url).scheme.in?(%w[http https]) rescue false) %>
    <%= link_to "View Readme", URI.parse(@project.readme_url).to_s, class: "btn-primary", target: "_blank", rel: "noopener" %>
  <% end %>
</div>
